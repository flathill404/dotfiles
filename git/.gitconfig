[user]
	name = flathill404
	email = 38638577+flathill404@users.noreply.github.com
	# signingkey is per-machine — define in ~/.gitconfig.local:
	#   [user]
	#       signingkey = <full-fingerprint>

[commit]
	gpgsign = true

[init]
	defaultBranch = main

# ── Security ─────────────────────────────────────────────────────────────────
# credential.helper is OS-specific (osxkeychain on macOS, cache on Linux/WSL)
# and is written to ~/.gitconfig.local by scripts/setup.sh.

[transfer]
	fsckObjects = true

[fetch]
	fsckObjects = true
	prune = true
	pruneTags = true

[receive]
	fsckObjects = true

# ── Performance ──────────────────────────────────────────────────────────────
[core]
	fsmonitor = true
	untrackedCache = true
	commitGraph = true
	# delta is optional on Linux/WSL — fall back to less if absent
	pager = "if command -v delta >/dev/null 2>&1; then delta; else less; fi"
	autocrlf = input
	whitespace = fix

[pack]
	writeReverseIndex = true

# ── Delta (diff pager) ──────────────────────────────────────────────────────
[interactive]
	diffFilter = "if command -v delta >/dev/null 2>&1; then delta --color-only; else cat; fi"

[delta]
	navigate = true
	side-by-side = true
	line-numbers = true

# ── Diff / Merge ─────────────────────────────────────────────────────────────
[diff]
	algorithm = histogram
	colorMoved = default
	colorMovedWS = allow-indentation-change

[merge]
	conflictStyle = zdiff3

# ── Pull / Push ──────────────────────────────────────────────────────────────
[push]
	autoSetupRemote = true
	default = current

[pull]
	rebase = true

# ── Rebase ───────────────────────────────────────────────────────────────────
[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

# ── UI ───────────────────────────────────────────────────────────────────────
[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = -version:refname

# ── Aliases ──────────────────────────────────────────────────────────────────
[alias]
	co = checkout
	br = branch
	ci = commit
	st = status -sb
	sw = switch
	lg = log --oneline --graph --decorate --all
	unstage = reset HEAD --
	amend = commit --amend --no-edit
	last = log -1 HEAD
	undo = reset --soft HEAD~1

# ── LFS ──────────────────────────────────────────────────────────────────────
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f

# ── Machine-specific overrides ───────────────────────────────────────────────
[include]
	path = ~/.gitconfig.local
