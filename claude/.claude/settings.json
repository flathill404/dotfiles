{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "model": "claude-opus-4-8",
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "permissions": {
    "allow": [
      "Bash(grep *)",
      "Bash(git fetch*)",
      "Bash(go version)",
      "Bash(go env)",
      "Bash(go list *)",
      "Bash(go doc *)",
      "Bash(go mod graph)",
      "Bash(go mod why*)",
      "Bash(go mod verify)",
      "Bash(go vet *)",
      "Bash(brew list*)",
      "Bash(brew info*)",
      "Bash(brew search*)",
      "Bash(proto bin*)",
      "Bash(proto debug*)",
      "Bash(proto diagnose*)",
      "Bash(proto status*)",
      "Bash(proto versions*)",
      "Bash(moon action-graph*)",
      "Bash(moon bin*)",
      "Bash(moon hash*)",
      "Bash(moon project*)",
      "Bash(moon project-graph*)",
      "Bash(moon projects*)",
      "Bash(moon query*)",
      "Bash(moon task*)",
      "Bash(moon task-graph*)",
      "Bash(moon tasks*)",
      "Bash(moon template*)",
      "Bash(moon templates*)",
      "Bash(moon run :lint*)",
      "Bash(moon run root:yaml-lint*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose config*)",
      "Bash(jq *)",
      "Bash(stow *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(rm -r *)",
      "Bash(sudo rm*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(sudo chmod*)",
      "Bash(sudo chown*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)"
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "theme": "dark"
}
