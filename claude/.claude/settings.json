{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git stash list*)",
      "Bash(git remote -v*)",
      "Bash(git fetch*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr checks*)",
      "Bash(gh issue view*)",
      "Bash(gh issue list*)",
      "Bash(gh repo view*)",
      "Bash(gh run view*)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(man *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(tree *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(diff *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(echo *)",
      "Bash(brew list*)",
      "Bash(brew info*)",
      "Bash(brew search*)",
      "Bash(proto bin*)",
      "Bash(proto debug*)",
      "Bash(proto diagnose*)",
      "Bash(proto status*)",
      "Bash(proto versions*)",
      "Bash(moon action-graph*)",
      "Bash(moon bin*)",
      "Bash(moon hash*)",
      "Bash(moon project*)",
      "Bash(moon project-graph*)",
      "Bash(moon projects*)",
      "Bash(moon query*)",
      "Bash(moon task*)",
      "Bash(moon task-graph*)",
      "Bash(moon tasks*)",
      "Bash(moon template*)",
      "Bash(moon templates*)",
      "Bash(docker ps*)",
      "Bash(docker images*)",
      "Bash(docker logs*)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(jq *)",
      "Bash(stow *)"
    ],
    "deny": [
      "Bash(rm -rf*)",
      "Bash(rm -fr*)",
      "Bash(rm -r *)",
      "Bash(sudo rm*)",
      "Bash(dd *)",
      "Bash(mkfs*)",
      "Bash(chmod -R*)",
      "Bash(chown -R*)",
      "Bash(sudo chmod*)",
      "Bash(sudo chown*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Read(**/.npmrc)",
      "Read(**/.netrc)"
    ]
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "agentPushNotifEnabled": true
}
